{
  "name": "mcp-server",
  "version": "1.0.0",
  "description": "生成AIが Ink シナリオを進行する stdio MCP サーバー",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "adventure-mcp-server": "src/index.ts"
  },
  "scripts": {
    "start": "node --experimental-transform-types --disable-warning=ExperimentalWarning src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "engine": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "^1.6.0"
  }
}
