{
  "name": "engine",
  "version": "1.0.0",
  "description": "InkJS scenario engine",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run --exclude **/scenarios-structure.spec.ts",
    "test:scenarios": "vitest run scenarios-structure",
    "build:ink": "node scripts/build-ink.ts",
    "setup:ink": "node scripts/install-inklecate.ts"
  },
  "dependencies": {
    "inkjs": "^2.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "typescript": "catalog:",
    "vitest": "^1.6.0"
  }
}
