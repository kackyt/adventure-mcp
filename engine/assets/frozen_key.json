{"inkVersion":21,"root":[["#","^title: 氷の鍵","/#",{"->":"antechamber"},["done",{"#f":5,"#n":"g-0"}],null],"done",{"antechamber":[["^ここは地下の古い前室。正面に頑丈な鉄の出口扉、奥に祭室へ続く通路、隅に埃をかぶった棚がある。","\n","ev","str","^棚を調べる","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^奥の祭室へ進む","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^鉄の出口扉を開ける","/str",{"VAR?":"has_key"},"/ev",{"*":".^.c-2","flg":5},"ev","str","^鉄の出口扉を開けようとする","/str",{"VAR?":"has_key"},"!","/ev",{"*":".^.c-3","flg":5},{"c-0":["\n",["ev",{"VAR?":"has_torch"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^棚の奥に、壁掛け用の松明が一本立てかけてあった。手に取った。","\n","ev",true,"/ev",{"VAR=":"has_torch","re":true},{"->":".^.^.^.3"},null]}],[{"->":".^.b"},{"b":["\n","^棚にはもう、めぼしい物は残っていない。","\n",{"->":".^.^.^.3"},null]}],"nop","\n",{"->":".^.^.^"},{"#f":5}],"c-1":["^ ",{"->":"altar_room"},"\n",{"#f":5}],"c-2":["\n","^氷の中から取り出した鍵が鍵穴にぴたりと合い、扉が重い音を立てて開いた。","\n",{"->":"escape"},{"#f":5}],"c-3":["\n","^扉は固く施錠されている。鍵がなければ開きそうにない。","\n",{"->":".^.^.^"},{"#f":5}]}],{"#f":1}],"altar_room":[["^祭室の中央に石の祭壇があり、その上に分厚い氷塊が据えられている。氷の中に、古びた鍵が閉じ込められているのが透けて見える。","\n","ev","str","^氷塊を調べる","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^祭壇の脇を調べる","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^氷を素手で割ろうとする","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^氷に油をかける","/str",{"VAR?":"has_oil"},{"VAR?":"oil_applied"},"!","&&",{"VAR?":"ice_melted"},"!","&&","/ev",{"*":".^.c-3","flg":5},"ev","str","^松明をかざす","/str",{"VAR?":"has_torch"},{"VAR?":"ice_melted"},"!","&&","/ev",{"*":".^.c-4","flg":5},"ev","str","^現れた鍵を取る","/str",{"VAR?":"ice_melted"},{"VAR?":"has_key"},"!","&&","/ev",{"*":".^.c-5","flg":5},"ev","str","^前室へ戻る","/str","/ev",{"*":".^.c-6","flg":4},{"c-0":["\n","^かなり分厚い氷だ。生半可な熱では、とても溶けそうにない。","\n",{"->":".^.^.^"},{"#f":5}],"c-1":["\n",["ev",{"VAR?":"has_oil"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^祭壇の脇に、口の空いた油壺が置かれていた。中の油はよく燃えそうだ。手に取った。","\n","ev",true,"/ev",{"VAR=":"has_oil","re":true},{"->":".^.^.^.3"},null]}],[{"->":".^.b"},{"b":["\n","^祭壇の脇には、もう何も残っていない。","\n",{"->":".^.^.^.3"},null]}],"nop","\n",{"->":".^.^.^"},{"#f":5}],"c-2":["\n","^拳を打ちつけても、冷たさに指がかじかむだけで、氷はびくともしない。","\n",{"->":".^.^.^"},{"#f":5}],"c-3":["\n","^とろりとした油が氷塊の表面いっぱいに広がった。","\n","ev",true,"/ev",{"VAR=":"oil_applied","re":true},{"->":".^.^.^"},{"#f":5}],"c-4":["\n",["ev",{"VAR?":"oil_applied"},"/ev",{"->":".^.b","c":true},{"b":["\n","^油に一気に引火し、轟と燃え上がった炎が氷塊を包んだ。氷は見る間に溶け落ち、中から鍵が現れた。","\n","ev",true,"/ev",{"VAR=":"ice_melted","re":true},{"->":".^.^.^.3"},null]}],[{"->":".^.b"},{"b":["\n","^松明の炎は弱々しく、氷の表面がわずかに濡れただけで終わった。これだけの厚みを溶かすには、もっと強い火が要る。","\n",{"->":".^.^.^.3"},null]}],"nop","\n",{"->":".^.^.^"},{"#f":5}],"c-5":["\n","^溶けた水の中から、濡れた鍵を拾い上げた。","\n","ev",true,"/ev",{"VAR=":"has_key","re":true},{"->":".^.^.^"},{"#f":5}],"c-6":["^ ",{"->":"antechamber"},"\n",{"#f":5}]}],{"#f":1}],"escape":["^鉄の扉の向こうには、地上へ続く階段があった。あなたは氷に閉ざされた鍵の謎を解き、地下から脱出した！","\n","done",{"#f":1}],"global decl":["ev",false,{"VAR=":"has_torch"},false,{"VAR=":"has_oil"},false,{"VAR=":"oil_applied"},false,{"VAR=":"ice_melted"},false,{"VAR=":"has_key"},"/ev","end",null],"#f":1}],"listDefs":{}}