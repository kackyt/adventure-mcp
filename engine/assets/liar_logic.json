{"inkVersion":21,"root":[["#","^title: 三人の証言","/#",{"->":"hub"},["done",{"#f":5,"#n":"g-0"}],null],"done",{"hub":[["^出口の鍵が盗まれた。三人——アレン・ボウ・カイ——のうち、盗人だけが嘘をつき、無実の二人は真実を述べる。","\n","ev",{"VAR?":"has_key"},"/ev",[{"->":".^.b","c":true},{"b":["\n","^取り戻した鍵が手の中にある。","\n",{"->":"hub.0.6"},null]}],"nop","\n","ev","str","^アレンの証言を聞く","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^ボウの証言を聞く","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^カイの証言を聞く","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^盗人を指摘する","/str",{"VAR?":"has_key"},"!","/ev",{"*":".^.c-3","flg":5},"ev","str","^鉄扉を開けて脱出する","/str",{"VAR?":"has_key"},"/ev",{"*":".^.c-4","flg":5},{"c-0":["^ ",{"->":"t_alen"},"\n",{"#f":5}],"c-1":["^ ",{"->":"t_bou"},"\n",{"#f":5}],"c-2":["^ ",{"->":"t_kai"},"\n",{"#f":5}],"c-3":["^ ",{"->":"accuse"},"\n",{"#f":5}],"c-4":["^ ",{"->":"escape"},"\n",{"#f":5}]}],{"#f":1}],"t_alen":["^アレン:「盗んだのはボウだ」","\n",{"->":"hub"},{"#f":1}],"t_bou":["^ボウ:「私は盗んでいない」","\n",{"->":"hub"},{"#f":1}],"t_kai":["^カイ:「アレンは嘘をついている」","\n",{"->":"hub"},{"#f":1}],"accuse":[["^盗人は誰だ。規則に照らして、矛盾なく成り立つのは一人だけのはず。","\n","ev","str","^アレン","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^ボウ","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^カイ","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^まだ判断できない（戻る）","/str","/ev",{"*":".^.c-3","flg":4},{"c-0":["^ ",{"->":"right_reveal"},"\n",{"#f":5}],"c-1":["^ ",{"->":"wrong_end"},"\n",{"#f":5}],"c-2":["^ ",{"->":"wrong_end"},"\n",{"#f":5}],"c-3":["^ ",{"->":"hub"},"\n",{"#f":5}]}],{"#f":1}],"right_reveal":["^「もし盗人がボウなら、無実のカイの『アレンは嘘』が偽になり、カイまで嘘つきになる。もし盗人がカイなら、アレンの言葉が真偽どちらにも取れず破綻する。矛盾なく収まるのはアレンが盗人のときだけだ」","\n","^アレンは観念し、鍵を差し出した。","\n","ev",true,"/ev",{"VAR=":"has_key","re":true},{"->":"hub"},{"#f":1}],"wrong_end":["^名指しされた者は静かに首を振った。規則と証言は食い違い、真の盗人は鍵を手に消えた。あなたは取り残された。","\n","end",{"#f":1}],"escape":["^取り戻した鍵で鉄扉を開け、あなたは脱出した。嘘と真実を腑分けした、明晰な推理だった。","\n","done",{"#f":1}],"global decl":["ev",false,{"VAR=":"has_key"},"/ev","end",null],"#f":1}],"listDefs":{}}